# Google Sheets Integration
# 1. Create a Google Cloud project and enable the Google Sheets API
# 2. Create a Service Account and download the JSON key
# 3. Paste the entire JSON key as a single line below
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# 4. Create a Google Sheet with 4 tabs named exactly:
#    - "Land Listings"
#    - "Investors"
#    - "Demand Requests"
#    - "CPO Interest"
# 5. Share the sheet with the service account email (Editor access)
# 6. Copy the Sheet ID from the URL (the long string between /d/ and /edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here
